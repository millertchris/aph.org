#!/bin/bash

## Description: Import database from SQL file and run search-replace
## Usage: setup-db [sql-file]
## Example: "ddev setup-db" or "ddev setup-db db/production.sql"

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Configuration - Dynamic URLs
# All production URLs that might appear in the database
OLD_URLS=("www.aph.org" "aph.org" "staging.aph.org")

# Plugins to deactivate after import (production-only plugins that break local dev)
# - wp-defender: 2FA, reCAPTCHA, login masking, brute force protection
DEACTIVATE_PLUGINS=("wp-defender")

# Derive new URL from DDEV environment (strips https:// and port)
if [ -n "${DDEV_PRIMARY_URL:-}" ]; then
    NEW_URL=$(echo "${DDEV_PRIMARY_URL}" | sed 's|https://||' | sed 's|http://||' | sed 's|:.*||')
else
    NEW_URL="aph.ddev.site"
fi

echo -e "${GREEN}APH.org Database Setup${NC}"
echo "========================"
echo ""

# Find SQL file
SQL_FILE="${1:-}"

if [ -z "$SQL_FILE" ]; then
    # Look for SQL file in db/ directory
    if [ -f /var/www/html/db/*.sql.gz ]; then
        SQL_FILE=$(ls /var/www/html/db/*.sql.gz 2>/dev/null | head -1)
        echo -e "${YELLOW}Found compressed SQL file: $SQL_FILE${NC}"
    elif [ -f /var/www/html/db/*.sql ]; then
        SQL_FILE=$(ls /var/www/html/db/*.sql 2>/dev/null | head -1)
        echo -e "${YELLOW}Found SQL file: $SQL_FILE${NC}"
    else
        echo -e "${RED}Error: No SQL file found.${NC}"
        echo ""
        echo "Please place your database export in the db/ directory:"
        echo "  - db/database.sql"
        echo "  - db/database.sql.gz"
        echo ""
        echo "Or specify the file path:"
        echo "  ddev setup-db /path/to/file.sql"
        exit 1
    fi
fi

# Check if file exists
if [ ! -f "$SQL_FILE" ]; then
    echo -e "${RED}Error: File not found: $SQL_FILE${NC}"
    exit 1
fi

# Confirm before proceeding
echo -e "${YELLOW}Warning: This will DROP all existing tables and import fresh data.${NC}"
echo ""
read -p "Continue? (y/N) " -n 1 -r
echo ""

if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    echo "Aborted."
    exit 0
fi

# Drop existing database and recreate
echo ""
echo "Step 1: Dropping existing database..."
mysql -u db -pdb -h db -e "DROP DATABASE IF EXISTS db; CREATE DATABASE db;"

# Import SQL file
echo "Step 2: Importing database..."
if [[ "$SQL_FILE" == *.gz ]]; then
    echo "  (Decompressing gzipped file...)"
    gunzip -c "$SQL_FILE" | mysql -u db -pdb -h db db
else
    mysql -u db -pdb -h db db < "$SQL_FILE"
fi
echo -e "${GREEN}  Database imported successfully.${NC}"

# Run search-replace for all production URLs
# Using --skip-plugins --skip-themes to avoid fatal errors from plugin incompatibilities
echo "Step 3: Running search-replace..."
for OLD_URL in "${OLD_URLS[@]}"; do
    echo "  Replacing: https://$OLD_URL -> https://$NEW_URL"
    wp search-replace "https://$OLD_URL" "https://$NEW_URL" \
        --all-tables --skip-columns=guid --report-changed-only \
        --skip-plugins --skip-themes || true
    echo "  Replacing: http://$OLD_URL -> https://$NEW_URL"
    wp search-replace "http://$OLD_URL" "https://$NEW_URL" \
        --all-tables --skip-columns=guid --report-changed-only \
        --skip-plugins --skip-themes || true
done

# Deactivate production-only plugins that break local development
echo "Step 4: Deactivating production-only plugins..."
for PLUGIN in "${DEACTIVATE_PLUGINS[@]}"; do
    if wp plugin is-installed "$PLUGIN" --skip-plugins --skip-themes 2>/dev/null; then
        wp plugin deactivate "$PLUGIN" --skip-plugins --skip-themes 2>/dev/null && \
            echo -e "  ${GREEN}Deactivated: $PLUGIN${NC}" || \
            echo -e "  ${YELLOW}Already inactive: $PLUGIN${NC}"
    fi
done

# Flush rewrite rules
echo "Step 5: Flushing rewrite rules..."
wp rewrite flush --skip-plugins --skip-themes

# Clear any caches
echo "Step 6: Clearing caches..."
wp cache flush --skip-plugins --skip-themes 2>/dev/null || true
wp transient delete --all --skip-plugins --skip-themes 2>/dev/null || true

echo ""
echo -e "${GREEN}Database setup complete!${NC}"
echo ""
echo "Next steps:"
echo "  1. Reset your admin password:"
echo "     wp user update <username> --user_pass='password'"
echo "  2. Visit https://$NEW_URL"
echo "  3. Log in at https://$NEW_URL/wp/wp-admin"
echo ""
