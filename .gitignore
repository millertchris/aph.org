# ==============================================================================
# APH.org - Git Ignore
# ==============================================================================

# WordPress core (Composer-managed)
/web/wp/

# Vendor directory (Composer-managed)
/vendor/

# ==============================================================================
# Environment Files
# ==============================================================================
.env
.env.*
!.env.example

# ==============================================================================
# Database
# ==============================================================================
/db/*.sql
/db/*.sql.gz
*.sql
*.sql.gz

# ==============================================================================
# Logs & Cache
# ==============================================================================
*.log
/web/app/debug.log
/web/app/wphb-cache/
/web/app/wphb-logs/
/web/app/cache/
/web/app/upgrade/
/web/app/upgrade-temp-backup/

# ==============================================================================
# Security
# ==============================================================================
/web/app/.defender-security-quarantine/
/web/app/wp-defender-secrets.php

# ==============================================================================
# WordPress Uploads (S3 handles media in production)
# ==============================================================================
/web/app/uploads/*
!/web/app/uploads/.gitkeep

# ==============================================================================
# Production Cache Drop-ins
# ==============================================================================
/web/app/object-cache.php
/web/app/advanced-cache.php

# ==============================================================================
# Node.js
# ==============================================================================
node_modules/
npm-debug.log
yarn-error.log

# ==============================================================================
# DDEV
# ==============================================================================
.ddev/.gitignore
.ddev/db_snapshots/
.ddev/*.local.yaml
.ddev/.webimageBuild/
.ddev/.dbimageBuild/
.ddev/mutagen/
.ddev/.sshimageBuild/

# ==============================================================================
# IDE & Editor
# ==============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/

# ==============================================================================
# Operating System
# ==============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ==============================================================================
# Local Configuration
# ==============================================================================
*.local.json
.claude/settings.local.json
.claude/instance.json

# ==============================================================================
# Secrets (never commit API keys)
# ==============================================================================
.claude/secrets/
**/secrets/*.env
anthropic.env
notion.env
github.env
openai.env
auth.json

# ==============================================================================
# Build Artifacts
# ==============================================================================
/web/app/themes/*/dist/
/web/app/themes/*/build/

# ==============================================================================
# Archive (not for version control)
# ==============================================================================
*.tar
*.tar.gz
