# APH.org E2E Test Configuration
# Copy to .env.test and update values

# Target site URL (default: local DDEV)
TEST_URL=https://aph.ddev.site

# Test customer credentials (created by global-setup if they don't exist)
TEST_CUSTOMER_EMAIL=test-customer@aph.org
TEST_CUSTOMER_PASSWORD=testpassword123

# Test CSR credentials (for admin-side testing — future)
# TEST_CSR_EMAIL=test-csr@aph.org
# TEST_CSR_PASSWORD=testpassword123
