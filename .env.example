# APH.org Local Development Environment
# Copy this file to .env and update values as needed

# ==============================================================================
# DATABASE SETTINGS (DDEV provides these automatically)
# ==============================================================================
DB_NAME='db'
DB_USER='db'
DB_PASSWORD='db'
DB_HOST='db'
DB_PREFIX='wp_'
# DB_SSL=false

# ==============================================================================
# SITE URLs
# ==============================================================================
WP_HOME='https://aph.ddev.site'
WP_SITEURL='https://aph.ddev.site/wp'

# ==============================================================================
# ENVIRONMENT
# ==============================================================================
WP_ENV='development'
WP_DEBUG=true
WP_DEBUG_LOG=true
DISABLE_WP_CRON=false

# ==============================================================================
# AUTHENTICATION KEYS AND SALTS
# Generate new ones at: https://roots.io/salts.html
# ==============================================================================
AUTH_KEY='generateme-auth-key-replace-with-unique-phrase'
SECURE_AUTH_KEY='generateme-secure-auth-key-replace-with-unique-phrase'
LOGGED_IN_KEY='generateme-logged-in-key-replace-with-unique-phrase'
NONCE_KEY='generateme-nonce-key-replace-with-unique-phrase'
AUTH_SALT='generateme-auth-salt-replace-with-unique-phrase'
SECURE_AUTH_SALT='generateme-secure-auth-salt-replace-with-unique-phrase'
LOGGED_IN_SALT='generateme-logged-in-salt-replace-with-unique-phrase'
NONCE_SALT='generateme-nonce-salt-replace-with-unique-phrase'

# ==============================================================================
# S3 / WP OFFLOAD MEDIA
# Configure to serve media from production S3 bucket
# ==============================================================================
# AS3CF_SETTINGS_PROVIDER='aws'
# AS3CF_SETTINGS_BUCKET='aph-media'
# AS3CF_SETTINGS_REGION='us-east-1'
# AS3CF_COPY_TO_S3=false
# AS3CF_REMOVE_LOCAL=false
# AS3CF_DELIVERY_PROVIDER='aws'
# AS3CF_DELIVERY_DOMAIN='media.aph.org'
# AWS_ACCESS_KEY_ID='your-access-key'
# AWS_SECRET_ACCESS_KEY='your-secret-key'

# ==============================================================================
# PLUGIN LICENSE KEYS
# ==============================================================================
# FACETWP_LICENSE_KEY=''
# ACF_PRO_LICENSE=''
# ACP_LICENCE=''
# WPMDB_LICENCE=''
# WPMUDEV_APIKEY=''
# URE_LICENSE_KEY=''

# ==============================================================================
# LICENSE MANAGER FOR WOOCOMMERCE
# ==============================================================================
# LMFWC_PLUGIN_SECRET=''
# LMFWC_PLUGIN_DEFUSE=''

# ==============================================================================
# FQ AND NET API CREDENTIALS
# ==============================================================================
# FQ_URL_PRD=''
# FQ_KEY_PRD=''
# FQ_URL_STG=''
# FQ_KEY_STG=''
# NT_URL_PRD=''
# NT_USR_PRD=''
# NT_PSW_PRD=''
# NT_URL_STG=''
# NT_USR_STG=''
# NT_PSW_STG=''

# ==============================================================================
# HUMANWARE API
# ==============================================================================
# HUMANWARE_API_SECRET=''

# ==============================================================================
# ENVIRONMENT URLs (for stage switcher)
# ==============================================================================
# STAGING_URL='https://aph-staging.prolificdigital.io/'
# PRODUCTION_URL='https://www.aph.org/'

# ==============================================================================
# CORS (comma-separated origins, or leave blank for defaults)
# ==============================================================================
# CORS_ALLOWED_ORIGINS=''
